{
  "name": "Cloud Monitor",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "forwardPorts": [5000, 5601, 9200],
  "portsAttributes": {
    "5000": {"label": "Flask App", "onAutoForward": "openBrowser"},
    "5601": {"label": "Kibana", "onAutoForward": "notify"},
    "9200": {"label": "Elasticsearch", "onAutoForward": "notify"}
  },
  "postCreateCommand": "pip install flask python-dotenv",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}


